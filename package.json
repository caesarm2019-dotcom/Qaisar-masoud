    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "emoji-picker-react": "^4.19.1",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
