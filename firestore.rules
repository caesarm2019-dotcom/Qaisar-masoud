rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidAd(data) {
      return data.keys().hasAll(['title', 'price', 'category', 'sellerId', 'createdAt', 'status'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 50
        && data.sellerId == request.auth.uid
        && data.status in ['active', 'sold', 'deleted']
        && (data.get('description', '') is string && data.get('description', '').size() <= 2000)
        && (data.get('images', []) is list && data.get('images', []).size() <= 10)
        && (data.get('watchers', []) is list && data.get('watchers', []).size() <= 1000);
    }

    function isValidUser(data) {
       return data.keys().hasAll(['displayName', 'email'])
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.get('whatsappNumber', '') is string && data.get('whatsappNumber', '').size() <= 20)
        && (data.get('notificationPrefs', null) == null || data.get('notificationPrefs', {}) is map)
        && (data.get('favoriteCategories', null) == null || data.get('favoriteCategories', []) is list);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'userName', 'text', 'createdAt'])
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.text is string && data.text.size() > 0 && data.text.size() <= 500
        && data.createdAt == request.time;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['participants', 'adId', 'lastMessageAt', 'adTitle', 'lastMessage', 'unreadCount'])
        && data.participants is list && data.participants.size() == 2
        && request.auth.uid in data.participants
        && data.adId is string
        && data.adTitle is string
        && data.lastMessage is string
        && data.unreadCount is map;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt', 'read'])
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() <= 2000
        && (data.text.size() > 0 || data.get('imageUrl', null) != null || data.get('audioUrl', null) != null || data.get('offerAmount', 0) > 0)
        && data.read is bool
        && (data.get('type', 'text') in ['text', 'image', 'voice', 'offer'])
        && (data.get('offerStatus', null) == null || data.get('offerStatus', '') in ['pending', 'accepted', 'rejected', 'countered']);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.userId is string
        && data.title is string
        && data.message is string
        && data.read == false
        && (data.get('data', null) == null || data.get('data', {}) is map)
        && (data.createdAt == request.time || !data.keys().hasAll(['createdAt']));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['reviewerId', 'reviewerName', 'reviewerPhoto', 'rating', 'comment', 'createdAt'])
        && data.reviewerId == request.auth.uid
        && data.reviewerName is string && data.reviewerName.size() <= 100
        && data.reviewerPhoto is string && data.reviewerPhoto.size() <= 500
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    // Collection Rules
    match /ads/{adId} {
      allow get: if true;
      allow list: if true; // Public marketplace
      
      allow create: if isSignedIn() 
        && isValidId(adId) 
        && isValidAd(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isSignedIn()
        && (
          (existing().sellerId == request.auth.uid && isValidAd(incoming()) && (
            // Action: Edit Ad info
            incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'condition', 'images', 'location', 'contactMethod', 'whatsappNumber', 'status'])
          )) || 
          (isVerified() && incoming().diff(existing()).affectedKeys().hasOnly(['watchers'])) ||
          isAdmin()
        );
        
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isVerified() && isValidComment(incoming());
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }

    match /users/{userId} {
      allow get: if true;
      allow list: if true; // To show seller lists/search
      
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'whatsappNumber', 'phoneNumber', 'address', 'birthDate', 'fcmToken', 'notificationPrefs', 'favoriteCategories']))
        || isAdmin()
      );

      match /favorites/{favoriteId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId 
          && incoming().adId is string && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /blocks/{blockId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId 
          && incoming().blockedUserId is string && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && userId != request.auth.uid
          && isValidReview(incoming());
        allow delete: if isAdmin() || (isSignedIn() && existing().reviewerId == request.auth.uid);
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants
        && incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'lastMessageAt', 'unreadCount', 'typing']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn() 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'offerStatus']);
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }


    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console
    }
  }
}
